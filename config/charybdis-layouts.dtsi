#include <physical_layouts.dtsi>

/ {
    charybdis_physical_layout: charybdis_physical_layout {
        compatible = "zmk,physical-layout";
        display-name = "Charybdis Nano 3x5";

        kscan = <&kscan0>;
        transform = <&five_column_transform>;

        keys
            // Left Half - Main Keys
            //                       w   h    x    y     rot    rx    ry
            = <&key_physical_attrs 100 100    0   58       0     0     0>
            , <&key_physical_attrs 100 100  100   13       0     0     0>
            , <&key_physical_attrs 100 100  200    0       0     0     0>
            , <&key_physical_attrs 100 100  300   13       0     0     0>
            , <&key_physical_attrs 100 100  400   13       0     0     0>
            , <&key_physical_attrs 100 100  800   13       0     0     0>
            , <&key_physical_attrs 100 100  900   13       0     0     0>
            , <&key_physical_attrs 100 100 1000    0       0     0     0>
            , <&key_physical_attrs 100 100 1100   13       0     0     0>
            , <&key_physical_attrs 100 100 1200   58       0     0     0>
            , <&key_physical_attrs 100 100    0  158       0     0     0>
            , <&key_physical_attrs 100 100  100  113       0     0     0>
            , <&key_physical_attrs 100 100  200  100       0     0     0>
            , <&key_physical_attrs 100 100  300  113       0     0     0>
            , <&key_physical_attrs 100 100  400  113       0     0     0>

            // Right Half - Main Keys
            //                       w   h    x    y     rot    rx    ry
            , <&key_physical_attrs 100 100  800  113       0     0     0>
            , <&key_physical_attrs 100 100  900  113       0     0     0>
            , <&key_physical_attrs 100 100 1000  100       0     0     0>
            , <&key_physical_attrs 100 100 1100  113       0     0     0>
            , <&key_physical_attrs 100 100 1200  158       0     0     0>
            , <&key_physical_attrs 100 100    0  258       0     0     0>
            , <&key_physical_attrs 100 100  100  213       0     0     0>
            , <&key_physical_attrs 100 100  200  200       0     0     0>
            , <&key_physical_attrs 100 100  300  213       0     0     0>
            , <&key_physical_attrs 100 100  400  213       0     0     0>
            , <&key_physical_attrs 100 100  800  213       0     0     0>
            , <&key_physical_attrs 100 100  900  213       0     0     0>
            , <&key_physical_attrs 100 100 1000  200       0     0     0>
            , <&key_physical_attrs 100 100 1100  213       0     0     0>
            , <&key_physical_attrs 100 100 1200  258       0     0     0>

            // Thumb Clusters
            //                       w   h    x    y     rot    rx    ry
            , <&key_physical_attrs 100 100  248  313       0     0     0>
            , <&key_physical_attrs 100 100  248  313    1500   298   790>
            , <&key_physical_attrs 100 100  248  313    3000   298   790>
            , <&key_physical_attrs 100 100  952  313 (-3000)  1002   790>
            , <&key_physical_attrs 100 100  952  313 (-1500)  1002   790>
            ;
    };
};
